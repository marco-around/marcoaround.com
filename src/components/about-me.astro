---
import { Icon } from 'astro-icon/components'
import aboutMeSprite from '../assets/images/spritesheet-about-me.webp'
---

<section
	id='about-me-section'
	class='bg-background diagonal-bg flex h-dvh snap-center flex-col gap-6 p-4 md:gap-12 md:p-12'
>
	<div class='flex items-center gap-4'>
		<div
			class='bg-primary animate-blink size-3 rounded-full duration-75 md:size-3.5'
		>
		</div>
		<span
			id='typewriter-whoami'
			class='text-secondary font-geist-mono text-base md:text-xl'
		>
			marco@portfolio:~$ whoami
		</span>
	</div>

	<div class='grid h-full grid-cols-1 gap-6 md:grid-cols-2 md:gap-28'>
		<div
			id='about-me-image-container'
			class='border-border relative size-full border-2 border-dashed'
		>
			<div
				class='absolute top-4 right-4 left-4 z-10 flex items-center justify-between gap-4 md:top-6 md:right-6 md:left-6'
			>
				<span
					id='typewriter-hello'
					class='text-secondary font-geist-mono text-base md:text-xl'
				>
					Hello!
				</span>
				<div
					class='bg-primary animate-blink size-3 rounded-full duration-75 md:size-3.5'
				>
				</div>
			</div>

			<div
				class='absolute inset-0 flex size-full items-center justify-center overflow-hidden'
			>
				<div
					id='sprite-wave-frame'
					class='aspect-video min-h-full min-w-full shrink-0 bg-size-[200%_100%]'
					style={`background-image: url('${aboutMeSprite.src}'); background-position: 0% 0%;`}
					aria-label='Me in pixel art'
					role='img'
				>
				</div>
			</div>
		</div>

		<div class='flex flex-col'>
			<h2
				class='text-foreground font-geist-mono mb-6 text-2xl font-bold md:mb-12 md:text-[2rem]'
			>
				<span id='typewriter-tittle'>Hello, I'm Marco!</span>
			</h2>

			<p
				class='text-secondary font-geist-mono [&_strong]:text-primary mb-4 text-base leading-[160%] md:mb-6 md:text-xl [&_strong]:font-normal'
			>
				<span id='typewriter-paragraph-1'>
					A <strong>software developer</strong> deeply focused on the intersection
					of product and business. My core philosophy is that business-oriented
					<strong> code quality </strong> is the true catalyst for any company's
					<strong>growth</strong> and <strong>success</strong>.
				</span>
			</p>

			<p
				class='text-secondary font-geist-mono [&_strong]:text-primary mb-4 text-base leading-[160%] md:mb-6 md:text-xl [&_strong]:font-normal'
			>
				<span id='typewriter-paragraph-2'>
					I specialize in guiding <strong>team architecture</strong>, scaling
					systems, and elevating overall project <strong>design</strong>. While
					I am currently developing a logistics system, I am always open to
					connecting and discussing innovative solutions that require a
					<strong>strategic</strong>, product-driven perspective.
				</span>
			</p>

			<span
				id='typewriter-cursor-about'
				class='text-secondary font-jetbrains-mono'>█</span
			>

			<footer
				id='footer-control'
				class='border-muted text-muted mt-auto hidden items-center justify-between border-b-2 md:flex'
			>
				<span
					id='current-time'
					class='font-geist-mono text-base font-medium md:text-xl'
				>
					--:--
				</span>

				<div class='flex items-center'>
					<Icon name='signal' class='size-9 md:size-12' />
					<Icon name='battery' class='size-9 md:size-12' />
				</div>
			</footer>
		</div>
	</div>
</section>

<script>
	import gsap from 'gsap'
	import { ScrollTrigger } from 'gsap/ScrollTrigger'
	import { TextPlugin } from 'gsap/TextPlugin'

	gsap.registerPlugin(TextPlugin, ScrollTrigger)

	const whoamiText = document.getElementById('typewriter-whoami')
	const imageContainer = document.getElementById('about-me-image-container')
	const helloText = document.getElementById('typewriter-hello')
	const title = document.getElementById('typewriter-tittle')
	const paragraph1 = document.getElementById('typewriter-paragraph-1')
	const paragraph2 = document.getElementById('typewriter-paragraph-2')
	const cursor = document.getElementById('typewriter-cursor-about')
	const footer = document.getElementById('footer-control')

	if (
		whoamiText &&
		imageContainer &&
		helloText &&
		title &&
		title.parentElement &&
		paragraph1 &&
		paragraph1.parentElement &&
		paragraph2 &&
		paragraph2.parentElement &&
		cursor &&
		footer &&
		footer.parentElement
	) {
		// Armazena o conteúdo HTML original (preservando tags <strong>)
		const whoamiString = whoamiText.innerHTML.trim()
		const helloString = helloText.innerHTML.trim()
		const titleText = title.innerHTML.trim()
		const p1Text = paragraph1.innerHTML.trim()
		const p2Text = paragraph2.innerHTML.trim()

		// Usa o textContent para contar apenas os caracteres visíveis
		const whoamiLength = whoamiText.textContent?.length || 23
		const p1Length = paragraph1.textContent?.length || 200
		const p2Length = paragraph2.textContent?.length || 270
		const charSpeed = 0.007 // Velocidade base: 0.007s por caractere

		// Referências imutáveis para preservar o estreitamento de tipo dentro das closures
		const titleParent = title.parentElement
		const p1Parent = paragraph1.parentElement
		const p2Parent = paragraph2.parentElement
		const footerParent = footer.parentElement

		// Limpa o conteúdo inicial para a animação começar do zero
		whoamiText.innerHTML = ''
		helloText.innerHTML = ''
		title.innerHTML = ''
		paragraph1.innerHTML = ''
		paragraph2.innerHTML = ''

		// Estado inicial do footer, cursor e imagem para evitar FOUC
		gsap.set(footer, { opacity: 0, y: 40 })
		gsap.set(cursor, { opacity: 0 })
		gsap.set(imageContainer, { xPercent: -120, autoAlpha: 0 })

		// Cria a timeline com gatilho de scroll (ScrollTrigger)
		const timeline = gsap.timeline({
			scrollTrigger: {
				trigger: '#about-me-section',
				scroller: '.snap-y', // Define o container principal que possui o overflow/scroll
				start: 'top 70%', // Inicia quando o topo da seção cruza 70% da altura da tela
				toggleActions: 'play none none none',
			},
		})

		// 1. Digita o whoami no topo primeiro
		timeline.to(
			whoamiText,
			{ text: whoamiString, duration: whoamiLength * charSpeed, ease: 'none' },
			0
		)

		// Label de sincronização para os próximos elementos
		timeline.addLabel('main-content', '+=0.2')

		// 2. Animação da imagem vindo da esquerda
		timeline.to(
			imageContainer,
			{ xPercent: 0, autoAlpha: 1, duration: 1, ease: 'power3.out' },
			'main-content'
		)

		// Animação de digitação paralela para o "Hello!" (sem cursor)
		timeline.to(
			helloText,
			{ text: helloString, duration: 0.6, ease: 'none' },
			'main-content'
		)

		timeline
			// 1. Torna o cursor sólido e posiciona no final do título
			.call(() => {
				gsap.set(cursor, { opacity: 1 })
				titleParent.appendChild(cursor)
			})
			.to(title, { text: titleText, duration: 0.3, ease: 'none' })

			// 2. Transiciona o cursor para o parágrafo 1 e digita
			.call(() => {
				p1Parent.appendChild(cursor)
			})
			.to(
				paragraph1,
				{ text: p1Text, duration: p1Length * charSpeed, ease: 'none' },
				'+=0.1'
			)

			// 3. Transiciona o cursor para o parágrafo 2 e digita
			.call(() => {
				p2Parent.appendChild(cursor)
			})
			.to(
				paragraph2,
				{ text: p2Text, duration: p2Length * charSpeed, ease: 'none' },
				'+=0.1'
			)

			// 4. Inicia o piscar contínuo do cursor e retorna-o para a posição original (antes do footer)
			.call(() => {
				footerParent.insertBefore(cursor, footer)

				gsap.to(cursor, {
					opacity: 0,
					ease: 'steps(1)',
					repeat: -1,
					duration: 0.8,
					yoyo: true,
				})
			})

		// Animação paralela do footer iniciando junto com o conteúdo principal
		timeline.to(
			footer,
			{ opacity: 1, y: 0, duration: 2, ease: 'power3.out' },
			'main-content'
		)

		// Animação do pixel art acenando (3 repetições, inicia após a imagem chegar na posição)
		const waveFrame = document.getElementById('sprite-wave-frame')
		if (waveFrame) {
			const waveFrames = { frame: 0 }

			function updateWaveFrame(): void {
				if (!waveFrame) return
				const pos = Math.round(waveFrames.frame) * 100
				waveFrame.style.backgroundPosition = `${pos}% 0`
			}

			const waveTl = gsap.timeline({ repeat: 3 })
			waveTl
				.set(waveFrames, { frame: 1, onUpdate: updateWaveFrame }, 0.5)
				.set(waveFrames, { frame: 0, onUpdate: updateWaveFrame }, 1.0)

			timeline.add(waveTl, 'main-content+=1')
		}
	}

	function updateTime(): void {
		const timeElement = document.getElementById('current-time')
		if (timeElement) {
			const now = new Date()
			const hours = String(now.getHours()).padStart(2, '0')
			const minutes = String(now.getMinutes()).padStart(2, '0')
			timeElement.textContent = `${hours}:${minutes}`
		}
	}

	updateTime()
	setInterval(updateTime, 1000)
</script>
