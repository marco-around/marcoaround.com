---
import { Image } from 'astro:assets'
import backgroundPixelArt from '../assets/images/projects-background.webp'
import backgroundPixelArtMobile from '../assets/images/projects-background-mobile.webp'
import vhs from '../assets/images/vhs.webp'
import moDisc from '../assets/images/mo-disc.webp'
import diskette from '../assets/images/diskette.webp'
import cartridge from '../assets/images/cartridge.webp'
import Dialog from './ui/dialog.astro'

const projectsMoc = [
	{
		id: 'modal-vhs',
		slug: 'vhs',
		icon: vhs,
		projectName: 'VHS Project',
		description: 'Project description here.',
		stacks: 'React, TypeScript, Node.js',
		projectLink: '#',
		desktop: { top: '21%', left: '40%' },
		mobile: { top: '20%', left: '35%' },
	},
	{
		id: 'modal-diskette',
		slug: 'diskette',
		icon: diskette,
		projectName: 'Diskette Project',
		description: 'Project description here.',
		stacks: 'Astro, Tailwind, GSAP',
		projectLink: '#',
		desktop: { top: '58%', left: '30%' },
		mobile: { top: '53%', left: '10%' },
	},
	{
		id: 'modal-cartridge',
		slug: 'cartridge',
		icon: cartridge,
		projectName: 'Cartridge Project',
		description: 'Project description here.',
		stacks: 'Next.js, Prisma, PostgreSQL',
		projectLink: '#',
		desktop: { top: '35%', left: '59%' },
		mobile: { top: '43%', left: '60%' },
	},
	{
		id: 'modal-mo-disc',
		slug: 'mo-disc',
		icon: moDisc,
		projectName: 'MO Disc Project',
		description: 'Project description here.',
		stacks: 'Vue, Vite, Supabase',
		projectLink: '#',
		desktop: { top: '65%', left: '50%' },
		mobile: { top: '70%', left: '45%' },
	},
] as const
---

<section
	id='projects-section'
	class='bg-background text-foreground flex h-dvh snap-start flex-col justify-between gap-6 p-4 md:gap-12 md:p-12'
>
	<div class='flex items-center gap-4'>
		<div
			class='bg-primary animate-blink size-3 shrink-0 rounded-full md:size-3.5'
		>
		</div>
		<span class='text-secondary font-geist-mono text-base md:text-xl'>
			marco@portfolio:~$ <span id='projects-cmd'>render -projects</span>
		</span>
	</div>

	<div
		class='projects-container border-border relative mx-auto hidden aspect-video max-w-7xl border-2 md:block'
	>
		<div
			class='bg-border clip-triangle-x absolute left-1/2 z-10 h-14 w-full -translate-x-1/2 p-0.5 px-1 pt-0 md:w-1/3'
		>
			<div
				class='clip-triangle-x bg-background flex size-full items-center justify-center'
			>
				<h2 class='font-vt323 text-primary text-4xl'>Projects</h2>
			</div>
		</div>

		<Image
			src={backgroundPixelArt}
			alt='Pixel art background'
			class='size-full contrast-110 grayscale'
		/>

		<div class='absolute inset-0 z-10'>
			{
				projectsMoc.map((project) => (
					<button
						type='button'
						data-modal-target={project.id}
						class='project-item group absolute flex w-[8%] cursor-pointer flex-col items-center'
						style={`top: ${project.desktop.top}; left: ${project.desktop.left};`}
						aria-label={`Open ${project.projectName}`}
					>
						<Image
							src={project.icon}
							alt={`${project.slug} pixel art`}
							class='size-full transition-transform duration-200 hover:-translate-y-2'
						/>
					</button>
				))
			}
		</div>
	</div>

	<div
		class='projects-container border-border relative mx-auto aspect-9/16 h-full max-h-160 w-auto border-2 md:hidden'
	>
		<div
			class='bg-border clip-triangle-x absolute z-10 h-14 w-full p-0.5 px-1 pt-0'
		>
			<div
				class='clip-triangle-x bg-background flex size-full items-center justify-center'
			>
				<h2 class='font-vt323 text-primary text-3xl md:text-5xl'>Projects</h2>
			</div>
		</div>

		<Image
			src={backgroundPixelArtMobile}
			alt='Pixel art background'
			class='size-full contrast-110 grayscale'
		/>

		<div class='absolute inset-0 z-10'>
			{
				projectsMoc.map((project) => (
					<button
						type='button'
						data-modal-target={project.id}
						class={`project-item group absolute flex w-[24%] cursor-pointer flex-col items-center`}
						style={`top: ${project.mobile.top}; left: ${project.mobile.left};`}
						aria-label={`Open ${project.projectName}`}
					>
						<Image
							src={project.icon}
							alt={`${project.slug} pixel art`}
							class='size-full transition-transform duration-200 hover:-translate-y-2'
						/>
					</button>
				))
			}
		</div>
	</div>

	<span
		id='projects-footer'
		class='font-geist-mono text-center text-xl md:text-2xl'
	>
		Render successful | Files: 4 | Available space: 2
	</span>
</section>

{
	projectsMoc.map((project) => (
		<Dialog
			id={project.id}
			projectName={project.projectName}
			description={project.description}
			stacks={project.stacks}
			image={project.icon}
			projectLink={project.projectLink}
		/>
	))
}

<script>
	import gsap from 'gsap'
	import { ScrollTrigger } from 'gsap/ScrollTrigger'
	import { TextPlugin } from 'gsap/TextPlugin'

	import { lenis } from '../utils/lenis'

	gsap.registerPlugin(TextPlugin, ScrollTrigger)

	const section = document.getElementById('projects-section')
	const cmd = document.getElementById('projects-cmd')
	const containers = gsap.utils.toArray('.projects-container')
	const items = gsap.utils.toArray('.project-item')
	const footer = document.getElementById('projects-footer')

	// --- Modal open/close logic (event delegation) ---

	function openModal(modal: HTMLDialogElement): void {
		modal.showModal()

		lenis.stop()

		gsap.fromTo(
			modal,
			{ opacity: 0, scale: 0.92, y: 24 },
			{ opacity: 1, scale: 1, y: 0, duration: 0.35, ease: 'back.out(1.4)' }
		)
	}

	function closeModal(modal: HTMLDialogElement): void {
		gsap.to(modal, {
			opacity: 0,
			scale: 0.92,
			y: 24,
			duration: 0.2,
			ease: 'power2.in',
			onComplete() {
				modal.close()
				lenis.start()
			},
		})
	}

	// Delegated click on shelf items → open target modal
	const triggers = document.querySelectorAll<HTMLElement>('[data-modal-target]')
	triggers.forEach((trigger) => {
		trigger.addEventListener('click', function () {
			const targetId = trigger.dataset.modalTarget
			if (!targetId) return

			const modal = document.getElementById(
				targetId
			) as HTMLDialogElement | null
			if (!modal) return

			openModal(modal)
		})
	})

	// Close buttons inside modals
	const closeButtons =
		document.querySelectorAll<HTMLElement>('[data-close-modal]')
	closeButtons.forEach((btn) => {
		const modal = btn.closest('dialog') as HTMLDialogElement | null
		if (!modal) return

		btn.addEventListener('click', function () {
			closeModal(modal)
		})
	})

	// ESC key (cancel event) — animate close instead of instant
	const modals = document.querySelectorAll<HTMLDialogElement>('[data-modal]')
	modals.forEach((modal) => {
		modal.addEventListener('cancel', function (e: Event) {
			e.preventDefault()
			closeModal(modal)
		})

		// Click on backdrop (outside dialog content) to close
		modal.addEventListener('click', function (e: MouseEvent) {
			if (e.target === modal) {
				closeModal(modal)
			}
		})
	})

	// --- Scroll entrance animations ---

	if (section && cmd && containers.length > 0 && footer) {
		const cmdText = cmd.innerHTML.trim()
		cmd.innerHTML = ''

		gsap.set(containers, { opacity: 0, scale: 0.95 })
		gsap.set(items, { opacity: 0, scale: 0 })
		gsap.set(footer, { opacity: 0, y: 20 })

		const tl = gsap.timeline({
			scrollTrigger: {
				trigger: '#projects-section',
				start: 'top 70%',
				toggleActions: 'play none none none',
			},
		})

		tl.to(cmd, { text: cmdText, duration: 0.6, ease: 'none' })
			.to(
				containers,
				{ opacity: 1, scale: 1, duration: 0.6, ease: 'power3.out' },
				'+=0.2'
			)
			.to(
				items,
				{
					opacity: 1,
					scale: 1,
					duration: 0.5,
					stagger: 0.1,
					ease: 'back.out(1.5)',
				},
				'-=0.2'
			)
			.to(
				footer,
				{ opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' },
				'-=0.1'
			)
	}
</script>
