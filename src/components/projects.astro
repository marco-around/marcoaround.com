---
import { Image } from 'astro:assets'
import backgroundPixelArt from '../assets/images/projects-background.webp'
import vhs from '../assets/images/vhs.webp'
import moDisc from '../assets/images/mo-disc.webp'
import diskette from '../assets/images/diskette.webp'
import cartridge from '../assets/images/cartridge.webp'
---

<section
	class='bg-background text-foreground flex h-dvh snap-center flex-col gap-12 p-12'
>
	<div class='flex items-center gap-4'>
		<div class='bg-primary size-3.5 rounded-full'></div>
		<span class='text-secondary font-geist-mono text-xl'>
			marco@portfolio:~$ render -projects
		</span>
	</div>

	<div
		class='border-border relative flex size-full flex-col items-center border-2'
	>
		<div class='bg-border clip-triangle-x z-10 h-20 w-1/3 p-0.5 px-1 pt-0'>
			<div
				class='clip-triangle-x bg-background flex size-full items-center justify-center'
			>
				<h2 class='font-vt323 text-primary text-5xl'>Projects</h2>
			</div>
		</div>

		<Image
			src={backgroundPixelArt}
			alt='Pixel art background'
			class='absolute inset-0 size-full object-cover contrast-110 grayscale'
		/>

		<div class='absolute inset-0 z-10'>
			<a
				href='#'
				class='group absolute top-[20%] left-[30%] flex flex-col items-center transition-transform duration-200 hover:-translate-y-2'
			>
				<Image src={vhs} alt='vhs pixel art' class='h-[10%]' />
				<span
					class='font-vt323 -mt-5 ml-10 -rotate-27 transform text-2xl text-white/80 group-hover:text-white'
				>
					[Short Link]
				</span>
			</a>

			<a
				href='#'
				class='group absolute top-[55%] left-[30%] flex flex-col items-center transition-transform duration-200 hover:-translate-y-2'
			>
				<Image src={diskette} alt='diskette pixel art' class='h-[10%]' />
				<span
					class='font-vt323 -mt-2.5 ml-13 -rotate-24 transform text-2xl text-white/80 group-hover:text-white'
				>
					[Short Link]
				</span>
			</a>

			<a
				href='#'
				class='group absolute top-[25%] left-[59%] flex flex-col items-center transition-transform duration-200 hover:-translate-y-2'
			>
				<Image src={cartridge} alt='cartridge pixel art' class='h-[10%]' />
				<span
					class='font-vt323 -mt-6.5 ml-14 -rotate-25 transform text-2xl text-white/80 group-hover:text-white'
				>
					[Short Link]
				</span>
			</a>

			<a
				href='#'
				class='group absolute top-[62%] left-[54%] flex flex-col items-center transition-transform duration-200 hover:-translate-y-2'
			>
				<Image src={moDisc} alt='mo disc pixel art' class='h-[10%]' />
				<span
					class='font-vt323 -mt-5 ml-15 -rotate-25 transform text-2xl text-white/80 group-hover:text-white'
				>
					[Short Link]
				</span>
			</a>
		</div>
	</div>

	<span class='font-geist-mono text-center text-2xl'>
		Render successful | Files: 4 | Available space: 2
	</span>
</section>
