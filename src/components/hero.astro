							<span class='block' id='typewriter-row-2'>
								<span id='typewriter-line-2'></span>
							</span>
						</span>
					</h2>

					<div
						class='flex w-full flex-col gap-4 md:w-[30%] md:flex-row md:gap-6'
						id='hero-buttons'
					>
						<a
							href='cv.pdf'
							target='_blank'
							rel='noopener noreferrer'
							class='hero-btn hover:text-foreground hover:bg-background bg-foreground text-background font-vt323 flex h-12 w-full shrink-0 cursor-pointer items-center justify-center text-xl opacity-0 duration-150 hover:border hover:border-dashed md:text-2xl'
						>
							Download CV
						</a>

						<a
							href='mailto:marcosdevprofessional@gmail.com'
							class='hero-btn hover:bg-foreground hover:text-background border-foreground text-foreground font-vt323 flex h-12 w-full shrink-0 cursor-pointer items-center justify-center border border-dashed text-xl opacity-0 duration-150 hover:border-0 md:text-2xl'
						>
