---
import { Icon } from 'astro-icon/components'
import { Model } from './ui/model'
import { getTranslations } from '../utils/i18n'

const locale = Astro.currentLocale ?? 'en'
const t = getTranslations(locale)

const switchLanguageUrl = locale === 'en' ? '/pt-br' : '/'
---

<section class='h-dvh snap-center snap-always p-4 md:p-12'>
	<div class='border-border flex size-full flex-col border'>
		<header
			class='bg-border flex h-12 w-full items-center justify-between gap-3 px-3'
		>
			<div class='flex size-full gap-3 md:w-[40%]'>
				<div
					class='border-background flex size-full items-end overflow-hidden border-b'
				>
					<div
						id='hero-tab-home'
						class='bg-background text-border flex h-9 w-full items-center justify-between px-3'
					>
						<div class='flex items-center gap-3'>
							<Icon name='home' class='size-4' />
							<span class='font-semibold'>{t.home.hero.tabHome}</span>
						</div>

						<Icon name='x' class='size-4' />
					</div>
				</div>

				<div
					class='border-border flex size-full items-end overflow-hidden border-b'
				>
					<a
						id='hero-tab-writing'
						class='bg-background text-border flex h-9 w-full items-center justify-between px-3'
						href='/blog'
					>
						<div class='flex items-center gap-3'>
							<Icon name='pencil' class='size-4' />
							<span class='font-semibold'>{t.home.hero.tabWriting}</span>
						</div>

						<Icon name='x' class='size-4' />
					</a>
				</div>
			</div>

			<a
				href={switchLanguageUrl}
				class='text-border bg-background hover:text-foreground flex size-8 shrink-0 cursor-pointer items-center justify-center text-sm font-medium duration-150'
			>
				{locale === 'en' ? 'PT' : 'EN'}
			</a>
		</header>
		<main
			class='grid min-h-0 grow grid-cols-1 p-4 md:grid-cols-2 md:px-6 md:py-0'
		>
			<div class='flex flex-col justify-center gap-6 md:gap-12'>
				<div
					aria-hidden='true'
					class='font-jetbrains-mono text-primary flex flex-col items-center gap-2 text-[0.625rem] leading-[1.22] md:items-start md:text-base'
				>
					<div class='relative w-fit overflow-hidden'>
						<pre
							class='invisible'
							id='ascii-marco'>
в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—
в–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—
в–Ҳв–Ҳв•”в–Ҳв–Ҳв–Ҳв–Ҳв•”в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘
в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘
в–Ҳв–Ҳв•‘ в•ҡв•җв•қ в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ
в•ҡв•җв•қ     в•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ</pre>
						<div
							id='ascii-reveal-1'
							class='bg-primary absolute inset-y-0 left-0 w-full'
							style='transform: translateX(-101%)'
						>
						</div>
					</div>
					<div class='relative w-fit overflow-hidden'>
						<pre
							class='invisible'
							id='ascii-around'>
 в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—
в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—
в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в–Ҳв–Ҳв•— в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘
в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘
в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘ в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ
в•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ  в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ  в•ҡв•җв•җв•җв•қв•ҡв•җв•җв•җв•җв•җв•қ</pre>
						<div
							id='ascii-reveal-2'
							class='bg-primary absolute inset-y-0 left-0 w-full'
							style='transform: translateX(-101%)'
						>
						</div>
					</div>
				</div>

				<div class='flex flex-col gap-4 md:gap-6'>
					<h2
						class='text-secondary font-vt323 text-center text-lg leading-[1.32] md:text-start md:text-[2rem]'
					>
						<span class='sr-only'>
							{t.home.hero.description}
						</span>
						<span aria-hidden='true'>
							<span class='block' id='typewriter-row-1'>
								<span
									id='typewriter-line-1'
									data-text={t.home.hero.descriptionLine1}></span><span
									id='typewriter-cursor'
									class='text-secondary font-jetbrains-mono text-base md:text-2xl'
								>
									в–Ҳ
								</span>
							</span>
							<span class='block' id='typewriter-row-2'>
								<span
									id='typewriter-line-2'
									data-text={t.home.hero.descriptionLine2}></span>
							</span>
						</span>
					</h2>

					<div
						class='flex w-full flex-col gap-4 md:w-[30%] md:flex-row md:gap-6'
						id='hero-buttons'
					>
						<a
							href='cv.pdf'
							target='_blank'
							rel='noopener noreferrer'
							class='hero-btn hover:text-foreground hover:bg-background bg-foreground text-background font-vt323 flex h-12 w-full shrink-0 cursor-pointer items-center justify-center text-xl opacity-0 duration-150 hover:border hover:border-dashed md:text-2xl'
						>
							{t.home.hero.downloadCV}
						</a>

						<a
							href='mailto:marcosdevprofessional@gmail.com'
							class='hero-btn hover:bg-foreground hover:text-background border-foreground text-foreground font-vt323 flex h-12 w-full shrink-0 cursor-pointer items-center justify-center border border-dashed text-xl opacity-0 duration-150 hover:border-0 md:text-2xl'
						>
							{t.home.hero.contactMe}
						</a>
					</div>
				</div>
			</div>

			<Model client:only='react' />
		</main>
	</div>
</section>

<script>
	import gsap from 'gsap'
	import { TextPlugin } from 'gsap/TextPlugin'

	gsap.registerPlugin(TextPlugin)

	// Runs at parse time (loading screen still covers the page) вҖ” seeds GSAP transform cache
	const tabHome = document.getElementById('hero-tab-home')
	const tabWriting = document.getElementById('hero-tab-writing')
	if (tabHome && tabWriting) {
		gsap.set([tabHome, tabWriting], { yPercent: 110 })
	}

	function initHeroAnimation() {
		const tabHome = document.getElementById('hero-tab-home')
		const tabWriting = document.getElementById('hero-tab-writing')
		const reveal1 = document.getElementById('ascii-reveal-1')
		const reveal2 = document.getElementById('ascii-reveal-2')
		const asciiMarco = document.getElementById('ascii-marco')
		const asciiAround = document.getElementById('ascii-around')
		const line1 = document.getElementById('typewriter-line-1')
		const line2 = document.getElementById('typewriter-line-2')
		const cursor = document.getElementById('typewriter-cursor')
		const row2 = document.getElementById('typewriter-row-2')
		const buttons = document.querySelectorAll('.hero-btn')

		if (
			!tabHome ||
			!tabWriting ||
			!reveal1 ||
			!reveal2 ||
			!asciiMarco ||
			!asciiAround ||
			!line1 ||
			!line2 ||
			!cursor ||
			!row2 ||
			buttons.length === 0
		)
			return

		// MantГ©m o cursor sГіlido inicialmente
		gsap.set(cursor, { opacity: 1 })

		const master = gsap.timeline()

		master.addLabel('start', 0)

		// Tabs sliding up from below the header bar (initial offset set via inline style)

		master.to(
			tabHome,
			{
				yPercent: 0,
				duration: 0.7,
				ease: 'power3.out',
			},
			'start'
		)
		master.to(
			tabWriting,
			{ yPercent: 0, duration: 0.7, ease: 'power3.out' },
			'start+=0.15'
		)

		master.addLabel('ascii-start', 'start')

		// ASCII 1 Reveal (da esquerda para a direita e saindo para a direita)
		master.fromTo(
			reveal1,
			{ x: '-101%' },
			{ x: '0%', duration: 0.6, ease: 'power3.inOut' },
			'ascii-start'
		)
		master.set(asciiMarco, { visibility: 'visible' }, 'ascii-start+=0.6')
		master.to(
			reveal1,
			{ x: '130%', duration: 0.6, ease: 'power3.inOut' },
			'ascii-start+=0.6'
		)

		// ASCII 2 Reveal
		master.fromTo(
			reveal2,
			{ x: '-101%' },
			{ x: '0%', duration: 0.6, ease: 'power3.inOut' },
			'ascii-start+=0.2'
		)
		master.set(asciiAround, { visibility: 'visible' }, 'ascii-start+=0.8')
		master.to(
			reveal2,
			{ x: '110%', duration: 0.6, ease: 'power3.inOut' },
			'ascii-start+=0.8'
		)

		// Oculta os blocos completamente apГіs saГӯrem
		master.set(reveal1, { autoAlpha: 0 }, 'ascii-start+=1.2')
		master.set(reveal2, { autoAlpha: 0 }, 'ascii-start+=1.4')

		master.addLabel('typing', 'ascii-start')

		// Text Typing Row 1
		master.to(
			line1,
			{
				duration: 0.8,
				text: line1.dataset.text || '',
				ease: 'none',
			},
			'typing'
		)

		// Move o cursor para a prГіxima linha
		master.set(
			cursor,
			{
				onComplete: function () {
					row2.appendChild(cursor)
				},
			},
			'typing+=0.8'
		)

		// Text Typing Row 2
		master.to(
			line2,
			{
				duration: 0.3,
				text: line2.dataset.text || '',
				ease: 'none',
			},
			'typing+=0.8'
		)

		// Inicia o piscar contГӯnuo do cursor apГіs o tГ©rmino da digitaГ§ГЈo
		master.to(
			cursor,
			{
				opacity: 0,
				ease: 'steps(1)',
				repeat: -1,
				duration: 0.8,
				yoyo: true,
			},
			'typing+=1.1'
		)

		master.addLabel('buttons', 'ascii-start')

		// Fade In dos botГөes
		master.fromTo(
			buttons,
			{ y: 20, autoAlpha: 0 },
			{
				y: 0,
				autoAlpha: 1,
				duration: 0.8,
				stagger: 0.15,
				ease: 'power3.out',
			},
			'buttons'
		)
	}

	document.addEventListener('loading:complete', initHeroAnimation, {
		once: true,
	})
</script>
