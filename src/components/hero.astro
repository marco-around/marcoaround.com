			<Model client:only='react' />
		</main>
	</div>
</section>

<script>
	import gsap from 'gsap'
	import { TextPlugin } from 'gsap/TextPlugin'

	gsap.registerPlugin(TextPlugin)

	function initHeroAnimation() {
		const reveal1 = document.getElementById('ascii-reveal-1')
		const reveal2 = document.getElementById('ascii-reveal-2')
		const asciiMarco = document.getElementById('ascii-marco')
		const asciiAround = document.getElementById('ascii-around')
		const line1 = document.getElementById('typewriter-line-1')
		const line2 = document.getElementById('typewriter-line-2')
		const cursor = document.getElementById('typewriter-cursor')
		const row2 = document.getElementById('typewriter-row-2')
		const buttons = document.querySelectorAll('.hero-btn')

		if (
			!reveal1 ||
			!reveal2 ||
			!asciiMarco ||
			!asciiAround ||
			!line1 ||
			!line2 ||
			!cursor ||
			!row2 ||
			buttons.length === 0
		)
			return

		// MantГ©m o cursor sГіlido inicialmente
		gsap.set(cursor, { opacity: 1 })

		const master = gsap.timeline()

		master.addLabel('ascii-start', 0.2)

		// ASCII 1 Reveal (da esquerda para a direita e saindo para a direita)
		master.fromTo(
			reveal1,
			{ x: '-101%' },
			{ x: '0%', duration: 0.6, ease: 'power3.inOut' },
			'ascii-start'
		)
		master.set(asciiMarco, { visibility: 'visible' }, 'ascii-start+=0.6')
		master.to(
			reveal1,
			{ x: '130%', duration: 0.6, ease: 'power3.inOut' },
			'ascii-start+=0.6'
		)

		// ASCII 2 Reveal
		master.fromTo(
			reveal2,
			{ x: '-101%' },
			{ x: '0%', duration: 0.6, ease: 'power3.inOut' },
			'ascii-start+=0.2'
		)
		master.set(asciiAround, { visibility: 'visible' }, 'ascii-start+=0.8')
		master.to(
			reveal2,
			{ x: '110%', duration: 0.6, ease: 'power3.inOut' },
			'ascii-start+=0.8'
		)

		// Oculta os blocos completamente apГіs saГӯrem
		master.set(reveal1, { autoAlpha: 0 }, 'ascii-start+=1.2')
		master.set(reveal2, { autoAlpha: 0 }, 'ascii-start+=1.4')

		master.addLabel('typing', 'ascii-start')

		// Text Typing Row 1
		master.to(
			line1,
			{
				duration: 0.8,
				text: 'A traditional developer seeking new challenges',
				ease: 'none',
			},
			'typing'
		)

		// Move o cursor para a prГіxima linha
		master.set(
			cursor,
			{
				onComplete: function () {
					row2.appendChild(cursor)
				},
			},
			'typing+=0.8'
		)

		// Text Typing Row 2
		master.to(
			line2,
			{
				duration: 0.3,
				text: 'around the world...',
				ease: 'none',
			},
			'typing+=0.8'
		)

		// Inicia o piscar contГӯnuo do cursor apГіs o tГ©rmino da digitaГ§ГЈo
		master.to(
			cursor,
			{
				opacity: 0,
				ease: 'steps(1)',
				repeat: -1,
				duration: 0.8,
				yoyo: true,
			},
			'typing+=1.1'
		)

		master.addLabel('buttons', 'ascii-start')

		// Fade In dos botГөes
		master.fromTo(
			buttons,
			{ y: 20, autoAlpha: 0 },
			{
				y: 0,
				autoAlpha: 1,
				duration: 0.8,
				stagger: 0.15,
				ease: 'power3.out',
			},
			'buttons'
		)
	}

	document.addEventListener('loading:complete', initHeroAnimation, {
		once: true,
	})
</script>
