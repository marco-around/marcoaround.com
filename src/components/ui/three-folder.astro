---
import ThreeRow from './three-row.astro'

const folderItems = [
	{
		icon: 'typescript',
		suffix: 'typescript',
	},
	{
		prefix: '├──',
		icon: 'folder-open',
		suffix: 'frontend',
	},
	{
		prefix: '│   ├──',
		icon: 'react',
		suffix: 'react',
	},
	{
		prefix: '│   ├──',
		icon: 'vue',
		suffix: 'vue',
	},
	{
		prefix: '│   ├──',
		icon: 'tailwind',
		suffix: 'tailwind',
	},
	{
		prefix: '│   └──',
		icon: 'astro',
		suffix: 'astro',
	},
	{
		prefix: '├──',
		icon: 'folder-open',
		suffix: 'backend',
	},
	{
		prefix: '│   ├──',
		icon: 'node',
		suffix: 'node',
	},
	{
		prefix: '│   ├──',
		icon: 'fastify',
		suffix: 'fastify',
	},
	{
		prefix: '│   ├──',
		icon: 'prisma',
		suffix: 'prisma',
	},
	{
		prefix: '│   └──',
		icon: 'postgres',
		suffix: 'postgres',
	},
	{
		prefix: '├──',
		icon: 'github',
		suffix: '.git',
	},
	{
		prefix: '├──',
		icon: 'docker',
		suffix: 'docker',
	},
	{
		prefix: '├──',
		icon: 'figma',
		suffix: 'figma',
	},
	{
		prefix: '├──',
		icon: 'markdown',
		suffix: 'STACKS.md',
		isSelected: true,
	},
	{
		prefix: '└──',
		icon: 'paper',
		suffix: 'package.json',
	},
]
---

<div id='three-folder-container' class='-space-y-0.75 overflow-hidden'>
	{folderItems.map((item) => <ThreeRow {...item} />)}
</div>

<script>
	import gsap from 'gsap'
	import { ScrollTrigger } from 'gsap/ScrollTrigger'

	gsap.registerPlugin(ScrollTrigger)

	const container = document.getElementById('three-folder-container')

	if (container) {
		const rows = Array.from(container.children) as HTMLElement[]

		gsap.set(rows, { opacity: 0, x: 60 })

		gsap.to(rows, {
			opacity: 1,
			x: 0,
			duration: 0.5,
			ease: 'power2.out',
			stagger: 0.3,
			scrollTrigger: {
				trigger: container,
				scroller: '.snap-y',
				start: 'top 85%',
				toggleActions: 'play none none none',
			},
		})
	}
</script>
