---
import type { ImageMetadata } from 'astro'
import { Icon } from 'astro-icon/components'

interface Props {
	id: string
	projectName: string
	description: string
	stacks: string
	image: ImageMetadata
	projectLink: string
}

const { id, projectName, description, stacks, image, projectLink } = Astro.props
---

<dialog
	id={id}
	data-modal
	aria-labelledby={`modal-title-${id}`}
	class='backdrop:bg-background/75 m-auto max-h-[85dvh] w-full max-w-xl overflow-visible bg-transparent p-0 pb-6 opacity-100 backdrop:backdrop-blur-sm md:pl-6'
>
	<div class='relative size-full'>
		<div
			class='bg-background-secondary border-muted absolute top-6 -right-6 -bottom-6 left-6 border-2'
		>
			<div class='bg-muted h-16 w-full'></div>
		</div>

		<div
			class='bg-background border-border relative z-10 flex max-h-[calc(85dvh-1.5rem)] flex-col border-2'
		>
			<header
				class='bg-border text-background flex h-16 shrink-0 items-center justify-between px-4'
			>
				<span id={`modal-title-${id}`} class='font-geist-mono text-xl'>
					{projectName}
				</span>
				<button
					type='button'
					data-close-modal
					class='cursor-pointer duration-150 hover:scale-110'
					aria-label='Close modal'
				>
					<Icon name='x' class='size-6' />
				</button>
			</header>

			<div class='flex flex-col gap-4 overflow-y-auto p-4'>
				<span class='font-vt323 text-primary text-center text-5xl'>
					{projectName}
				</span>

				<img
					src={image.src}
					alt={'image ' + projectName}
					class='aspect-video w-full overflow-hidden'
				/>

				<p class='font-geist-mono text-secondary leading-[1.7]'>
					{description}
				</p>

				<div
					class='font-geist-mono flex flex-wrap items-baseline gap-x-2 gap-y-1'
				>
					<span class='text-primary font-medium'>Stacks:</span>
					<span class='text-secondary'>
						{stacks}
					</span>
				</div>

				<a
					href={projectLink}
					target='_blank'
					rel='noopener noreferrer'
					class='border-border font-vt323 text-secondary hover:text-background hover:bg-border flex h-10 shrink-0 items-center justify-center border-2 text-xl duration-150 hover:border-0'
				>
					View project
				</a>
			</div>
		</div>
	</div>
</dialog>
